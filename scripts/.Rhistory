obs <- read.csv("H:/Localization/data/observations.csv")
obs <- read.csv("H:/Localization/data/observations.csv")
obs <- read.csv("D:/Localization/data/observations.csv")
library(sf)
str(obs)
# convert to sf object (WGS84 lon/lat)
obs_sf <- st_as_sf(
obs,
coords = c("longitude", "latitude"),
crs = 4326
)
# transform to UTM Zone 13N (EPSG:32613)
obs_utm13 <- st_transform(obs_sf, crs = 32613)
# extract UTM coordinates back into columns
obs_utm13 <- cbind(
obs_utm13,
st_coordinates(obs_utm13)
)
# optional: drop geometry if you want a plain data frame
coords_utm13_df <- st_drop_geometry(coords_utm13)
obs_sf <- st_as_sf(
obs,
coords = c("longitude", "latitude"),
crs = 4326
)
View(obs_utm13)
